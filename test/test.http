
### Get All Products
GET http://localhost:4004/odata/v4/catalog/ProductsSet

### Filter Products by Stock
GET http://localhost:4004/odata/v4/catalog/ProductsSet?$filter=stock gt 5

### Order Products by Price Descending
GET http://localhost:4004/odata/v4/catalog/ProductsSet?$orderby=price desc

### Select Specific Fields
GET http://localhost:4004/odata/v4/catalog/ProductsSet?$select=name,price,stock

### Top 2 Products
GET http://localhost:4004/odata/v4/catalog/ProductsSet?$top=2

### Skip First Product
GET http://localhost:4004/odata/v4/catalog/ProductsSet?$skip=1

### Count Products
GET http://localhost:4004/odata/v4/catalog/ProductsSet/$count

### Get Currency Data
GET http://localhost:4004/odata/v4/catalog/Currencies

### Report Query
GET http://localhost:4004/odata/v4/catalog/ProductsSet?$select=name,price,stock,minStock


### Deep Insert POST Request
POST http://localhost:4004/odata/v4/catalog/ProductsSet
Content-Type: application/json

{
  "name": "Printer",
  "description": "Laser Printer",
  "price": 18000,
  "stock": 6,
  "minStock": 2,
  "rating": 4.3
}


### Call unbound action: GenerateReport
POST http://localhost:4004/analytics/GenerateReport
Content-Type: application/json

{
  "reportType": "Sales",
  "startDate": "2026-01-01",
  "endDate": "2026-05-31"
}

```http
### =========================================================
### SALES SERVICE - TEST FILE
### =========================================================

### Base URL
@baseUrl = http://localhost:4004

### =========================================================
### GET ALL SALES ORDERS
### =========================================================
GET {{baseUrl}}/sales/SalesOrders


### =========================================================
### CREATE NEW SALES ORDER
### =========================================================
POST {{baseUrl}}/sales/SalesOrders
Content-Type: application/json

{
  "customer_ID": "11111111-1111-1111-1111-111111111111",
  "orderDate": "2026-06-08",
  "items": [
    {
      "product_ID": "P100",
      "quantity": 2,
      "unitPrice": 500
    },
    {
      "product_ID": "P200",
      "quantity": 1,
      "unitPrice": 1200
    }
  ]
}


### =========================================================
### GET ORDER BY ID
### Replace UUID with actual order ID
### =========================================================
GET {{baseUrl}}/sales/SalesOrders(12345678-1234-1234-1234-123456789012)


### =========================================================
### UPDATE ORDER STATUS
### =========================================================
PATCH {{baseUrl}}/sales/SalesOrders(12345678-1234-1234-1234-123456789012)
Content-Type: application/json

{
  "status": "Confirmed"
}


### =========================================================
### DELETE ORDER
### =========================================================
DELETE {{baseUrl}}/sales/SalesOrders(12345678-1234-1234-1234-123456789012)


### =========================================================
### BOUND ACTION: CONFIRM ORDER
### =========================================================
POST {{baseUrl}}/sales/SalesOrders(12345678-1234-1234-1234-123456789012)/SalesService.confirm
Content-Type: application/json

{}


### =========================================================
### BOUND ACTION: CANCEL ORDER
### =========================================================
POST {{baseUrl}}/sales/SalesOrders(12345678-1234-1234-1234-123456789012)/SalesService.cancel
Content-Type: application/json

{
  "reason": "Customer changed their mind"
}


### =========================================================
### BOUND ACTION: SHIP ORDER
### =========================================================
POST {{baseUrl}}/sales/SalesOrders(12345678-1234-1234-1234-123456789012)/SalesService.ship
Content-Type: application/json

{
  "trackingNumber": "TRK-2026-ABC123",
  "carrier": "FedEx"
}


### =========================================================
### ANALYTICS SERVICE - GENERATE REPORT
### =========================================================
POST {{baseUrl}}/analytics/GenerateReport
Content-Type: application/json

{
  "reportType": "Sales",
  "startDate": "2026-01-01",
  "endDate": "2026-05-31"
}


### =========================================================
### ANALYTICS SERVICE - HEALTH CHECK
### =========================================================
POST {{baseUrl}}/analytics/PingHealth
Content-Type: application/json

{}



