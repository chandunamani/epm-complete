{
  "name": "epm-complete",
  "version": "1.0.0",
  "dependencies": {
    "@cap-js/hana": "^2",
    "@sap/cds": "^9.9.1",
    "sqlite3": "^6.0.1",
    "@sap/xssec": "^4"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2.4",
    "@sap/cds-dk": "^9",
    "cds-plugin-ui5": "^0.17.0"
  },
  "scripts": {
    "start": "cds-serve",
    "watch-po-management": "cds watch --open pomanagement/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-books": "cds watch --open books/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-project1": "cds watch --open project1/index.html?sap-ui-xx-viewCache=false --livereload false"
  },
  "private": true,
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/admin-authors",
    "app/admin-books",
    "app/browse",
    "app/genres",
    "app/po-management",
    "app/books",
    "app/project1"
  ],
  "cds": {
    "requires": {
      "auth": {
        "kind": "xsuaa",
        "[development]": {
          "kind": "mocked",
          "users": {
            "user": {
              "password": "pass",
              "roles": [
                "Viewer"
              ]
            },
            "manager": {
              "password": "pass",
              "roles": [
                "PurchaseManager"
              ]
            },
            "admin": {
              "password": "pass",
              "roles": [
                "Administrator"
              ]
            }
          }
        }
      }
    }
  }
}
